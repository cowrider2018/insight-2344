# 複製成 .env 並填入實際值
# Fugle Marketdata API 金鑰（https://developer.fugle.tw/）
FUGLE_MARKETDATA_API_KEY=

# Gmail 寄信（OAuth 授權，全程不需密碼）
# 將 Google Cloud Console 下載的 OAuth 用戶端憑證放專案根目錄為 credentials.json
# 首次執行 send_email.py 會開瀏覽器授權一次，自動產生 token.json，之後沿用
# 下面兩行可不填，預設即為 credentials.json / token.json
# GMAIL_CREDENTIALS_FILE=credentials.json
# GMAIL_TOKEN_FILE=token.json
MAIL_TO=
# 白話新手版的獨立收件名單（多人以逗號分隔）；留空則沿用 MAIL_TO
MAIL_TO_SIMPLE=
